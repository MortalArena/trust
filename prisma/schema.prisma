generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  // 🔐 Auth
  email         String?  @unique
  name          String?
  image         String?
  walletAddress String?  @unique
  // 👤 Privacy
  isAnonymous   Boolean  @default(false)
  displayName   String?
  bio           String?
  // 🏷️ Roles & Settings
  role              String   @default("user")
  matrixUserId      String?  @unique
  expertHeadline    String?
  expertBio         String?  @db.Text
  expertServiceTypes String[] @default([])
  acceptsAgentApi   Boolean  @default(true)
  expertBalanceUsd  Decimal  @default(0)
  totalPaidOutUsd   Decimal  @default(0)
  isSetupComplete   Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  wallets       Wallet[]
  expertPayouts ExpertPayout[]
  expertBots    ExpertBot[]
  groupComments GroupComment[]
  predictions   Prediction[]
  scores        TraderScore[]
  ownedGroups   Group[]        @relation("GroupOwner")
  memberships   GroupMember[]
  subscriptions Subscription[]
  groupReviews  GroupReview[]
  agentKeys     AgentKey[]
  accounts      Account[]
  sessions      Session[]

  @@index([walletAddress])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Wallet {
  id             String   @id @default(cuid())
  address        String
  chain          String   @default("polygon")
  label          String?
  isPrimary      Boolean  @default(false)
  lastSyncedAt   DateTime?
  signatureCount Int      @default(0)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   CachedTransaction[]
  createdAt      DateTime @default(now())

  @@unique([address, chain])
  @@index([userId])
  @@index([address])
}

model CachedTransaction {
  id          String   @id @default(cuid())
  signature   String
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  blockTime   Int
  type        String
  tokenIn     String?
  tokenOut    String?
  amountIn    Decimal?
  amountOut   Decimal?
  priceUsd    Decimal?
  rawData     Json
  processedAt DateTime @default(now())

  @@unique([walletId, signature])
  @@index([walletId, blockTime])
  @@index([signature])
}

model TraderScore {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roi              Decimal  @default(0)
  winRate          Decimal  @default(0)
  maxDrawdown      Decimal  @default(0)
  profitFactor     Decimal  @default(0)
  sharpeRatio      Decimal  @default(0)
  consistency      Decimal  @default(0)
  activityScore    Decimal  @default(0)
  riskLevel        String   @default("MEDIUM")
  trustScore       Decimal  @default(0)
  totalTrades      Int      @default(0)
  winningTrades    Int      @default(0)
  losingTrades     Int      @default(0)
  avgHoldTimeSecs  Int      @default(0)
  chainBreakdown   Json?
  lastCalculatedAt DateTime @default(now())
  createdAt        DateTime @default(now())

  @@unique([userId])
  @@index([trustScore])
  @@index([lastCalculatedAt])
}

model Prediction {
  id               String    @id @default(cuid())
  authorId         String
  author           User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  groupId          String?
  group            Group?    @relation(fields: [groupId], references: [id], onDelete: SetNull)

  // 📝 Prediction details (human-readable, what the seller "sells")
  title            String    // e.g. "BTC will reach 72k by Dec 31"
  description      String?   @db.Text // optional longer description
  category         String    @default("price_action") // price_action | binary | multiple_choice | numerical | polymarket | kalshi | stock | manual

  // 💰 For price_action / stock / numerical predictions  
  asset            String?   // BTC, ETH, SOL, AAPL, SPY, GOLD
  entryPrice       Decimal?
  targetPrice      Decimal?
  stopLoss         Decimal?
  timeframe        String?   // 1h, 4h, 1d, 1w, 1m, 3m

  // 🔀 For binary / multiple_choice predictions
  question         String?   // "Will BTC reach 100k before 2026?"
  predictedOutcome String?   // The option/side predicted (e.g. "Yes", "Trump", "Above $200")

  // 🔗 External platform linking (Polymarket, Kalshi, etc.)
  externalUrl      String?   // Full URL to the Polymarket/Kalshi market
  externalMarketId String?   // Condition ID or slug on external platform
  predictionSource String    @default("internal") // internal | polymarket | kalshi

  // 🔐 E2EE & On-Chain proof
  encryptedPayload String
  nonce            String
  contentHash      String    @unique
  solanaTxSig      String?   @unique
  onChainStatus    String    @default("pending")

  // 📊 Resolution
  expiresAt        DateTime?
  outcome          String?   @default("PENDING") // PENDING | WIN | LOSS | VOID
  resolvedPrice    Decimal?  // Price at resolution time (for verification)
  resolvedAt       DateTime?
  
  // 🏆 Auto-verification tracking
  verificationAttempts Int    @default(0)
  lastVerificationError String?
  verifiedAt        DateTime?
  
  visibility       String    @default("group") // public | group | private
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([authorId, createdAt])
  @@index([groupId, createdAt])
  @@index([outcome])
  @@index([expiresAt])
  @@index([contentHash])
  @@index([externalMarketId])
}

model Group {
  id                     String   @id @default(cuid())
  ownerId                String
  owner                  User     @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name                   String
  description            String?
  categorySlug           String   @default("crypto")
  subcategorySlug        String?
  matrixRoomId           String?  @unique
  isPublic               Boolean  @default(false)
  monthlyPriceUsd        Decimal  @default(0)
  yearlyPriceUsd         Decimal?
  lifetimePriceUsd       Decimal?
  subscriberCount        Int      @default(0)
  avgRating              Decimal  @default(0)
  reviewCount            Int      @default(0)
  encryptionKeyEncrypted String?
  serviceTypes           String[] @default([])
  allowPublicComments    Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  predictions   Prediction[]
  members       GroupMember[]
  subscriptions Subscription[]
  reviews       GroupReview[]
  comments      GroupComment[]

  @@index([ownerId])
  @@index([categorySlug])
  @@index([avgRating])
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId  String
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role     String   @default("member")
  joinedAt DateTime @default(now())

  @@unique([userId, groupId])
  @@index([groupId])
}

model Subscription {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId           String
  group             Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paymentTxSig      String       @unique
  paymentChain      String       @default("polygon")
  paymentReference  String
  amountUsd         Decimal
  platformFeeUsd    Decimal
  expertNetUsd      Decimal
  platformFeeBps    Int          @default(500)
  expertPayoutStatus String      @default("pending")
  expertPayoutTxSig String?
  startsAt          DateTime     @default(now())
  expiresAt         DateTime?
  status            String       @default("active")
  createdAt         DateTime     @default(now())
  review            GroupReview?

  @@index([userId])
  @@index([groupId])
  @@index([expiresAt])
  @@index([status])
  @@index([expertPayoutStatus])
  @@index([paymentReference])
}

model ExpertPayout {
  id          String   @id @default(cuid())
  expertId    String
  expert      User     @relation(fields: [expertId], references: [id], onDelete: Cascade)
  amountUsd   Decimal
  txSig       String?
  chain       String   @default("polygon")
  status      String   @default("pending")
  note        String?
  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@index([expertId])
  @@index([status])
}

model PlatformSettings {
  id                    String   @id @default("default")
  platformFeeBps        Int      @default(500)
  platformWalletPolygon String?
  platformWalletSolana  String?
  updatedAt             DateTime @updatedAt
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

/// Verified subscriber reviews only (paid + active/expired after paid period)
/// Public discussion on groups (public groups: any signed-in user; private: members only)
model GroupComment {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String   @db.VarChar(2000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId, createdAt])
  @@index([userId])
}

/// Bots experts sell, rent, or teach (marketplace listing)
model ExpertBot {
  id           String   @id @default(cuid())
  expertId     String
  expert       User     @relation(fields: [expertId], references: [id], onDelete: Cascade)
  name         String
  description  String?  @db.Text
  pricingModel String   @default("sell")
  priceUsd     Decimal?
  categorySlug String   @default("crypto")
  platform     String?
  isPublic     Boolean  @default(true)
  externalUrl  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([expertId])
  @@index([isPublic])
  @@index([categorySlug])
}

model GroupReview {
  id             String       @id @default(cuid())
  groupId        String
  group          Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String       @unique
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  rating         Int
  comment        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([rating])
}

model AgentKey {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyHash     String    @unique
  keyPrefix   String    @default("")
  name        String
  permissions String[]  @default(["read:subscriptions", "read:signals", "read:groups"])
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([keyHash])
  @@index([keyPrefix])
}

/// 🏆 Polymarket Trader Leaderboard Cache
/// Stores synced trader data from Polymarket with computed trust scores.
/// Updated every 5 minutes by cron job.
model PolymarketTrader {
  id             String   @id @default(cuid())
  proxyWallet    String   @unique
  displayName    String?
  pseudonym      String?
  verifiedBadge  Boolean  @default(false)
  xUsername      String?

  // Legacy V1 scores
  trustScore     Decimal  @default(0)
  edgeScore      Decimal  @default(0)
  winRate        Decimal  @default(0)
  roi            Decimal  @default(0)
  maxDrawdown    Decimal  @default(0)
  consistency    Decimal  @default(0)
  profitFactor   Decimal  @default(0)
  riskLevel      String   @default("MEDIUM")
  avgTradeSize   Decimal  @default(0)
  totalVolumeUsd Decimal  @default(0)
  timingScore    Decimal  @default(50)

  // V2 Reputation Engine scores
  predictiveScore     Decimal  @default(0)
  alphaScore          Decimal  @default(0)
  behaviorScore       Decimal  @default(0)
  confidenceScore     Decimal  @default(0)
  riskScore           Decimal  @default(0)
  masterPMI           Decimal  @default(0)

  forecastBrier       Decimal  @default(0)
  forecastLogLoss     Decimal  @default(0)
  forecastCalibration Decimal  @default(0)
  alpha24h            Decimal  @default(0)
  alpha7d             Decimal  @default(0)
  sectorAlpha         Decimal  @default(0)

  totalTrades    Int      @default(0)
  activityDays   Int      @default(0)
  categories     String[] @default([])

  lastSyncedAt   DateTime @default(now())
  createdAt      DateTime @default(now())

  trades     PolymarketTrade[]
  positions  PolymarketPosition[]

  @@index([trustScore])
  @@index([edgeScore])
  @@index([roi])
  @@index([categories])
  @@index([lastSyncedAt])
  @@index([masterPMI])
  @@index([predictiveScore])
}

/// Precomputed ranking boards (refreshed by cron — site reads from cache)
model IntelligenceRanking {
  id           String   @id @default(cuid())
  board        String
  categorySlug String?
  payload      Json
  traderCount  Int      @default(0)
  computedAt   DateTime @default(now())

  @@unique([board, categorySlug])
  @@index([board])
  @@index([computedAt])
}

/// ── Reputation Engine V2 ──
/// Raw trade data from Polymarket Data API
model PolymarketTrade {
  id           String   @id @default(cuid())
  traderId     String
  trader       PolymarketTrader @relation(fields: [traderId], references: [id], onDelete: Cascade)

  marketId       String
  conditionId    String
  marketTitle    String?
  category       String?

  side           String
  outcome        String
  price          Decimal
  shares         Decimal
  valueUsd       Decimal
  feeUsd         Decimal?

  entryProbability Decimal?

  timestamp      DateTime
  closedAt       DateTime?

  createdAt      DateTime @default(now())

  @@unique([traderId, marketId, conditionId, timestamp, side, outcome])
  @@index([traderId, timestamp])
  @@index([marketId])
  @@index([category])
}

/// Open/closed positions snapshot
model PolymarketPosition {
  id              String   @id @default(cuid())
  traderId        String
  trader          PolymarketTrader @relation(fields: [traderId], references: [id], onDelete: Cascade)

  marketId        String
  marketTitle     String?
  outcome         String
  avgEntry        Decimal
  currentProbability Decimal
  quantity        Decimal
  unrealizedPnL   Decimal
  realizedPnL     Decimal
  openedAt        DateTime
  closedAt        DateTime?

  @@index([traderId, closedAt])
  @@index([marketId])
}

/// Market probability snapshots over time
model MarketSnapshot {
  id           String   @id @default(cuid())
  marketId     String
  conditionId  String
  probability  Decimal
  liquidity    Decimal
  volume       Decimal
  timestamp    DateTime

  @@index([marketId, timestamp])
  @@index([timestamp])
}

/// Historical metric snapshots per trader
model TraderMetricHistory {
  id              String   @id @default(cuid())
  traderId        String
  date            DateTime @default(now())
  totalTrades     Int
  totalVolume     Decimal
  roi             Decimal
  winRate         Decimal
  maxDrawdown     Decimal
  predictiveScore Decimal
  alphaScore      Decimal
  masterPMI       Decimal

  @@unique([traderId, date])
  @@index([traderId, date])
}
